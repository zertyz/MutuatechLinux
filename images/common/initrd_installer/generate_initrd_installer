#!/usr/bin/env bash
set -euo pipefail

# ---- host machine vars ----
IMG="${IMG:-../artifacts/mutuatechlinux-general-x86_64.img}"
INITRD_SCRIPTS="${INITRD_SCRIPTS:-./initcpio}"
ARTIFACTS="${ARTIFACTS:-./artifacts}"
TARGET_ARCH="${TARGET_ARCH:-x86_64}"

# ---- VM vars
KERNEL_PKG="${KERNEL_PKG:-linux}"
KERNEL_BASENAME="${KERNEL_BASENAME:-vmlinuz-${KERNEL_PKG}}"
KERNEL_FALLBACK_BASENAME="${KERNEL_FALLBACK_BASENAME:-Image}"
INITRAMFS_BASENAME="${INITRAMFS_BASENAME:-initramfs-${KERNEL_PKG}.img}"

[ "$EUID" -ne 0 ] && { echo "Please run this as root: sudo $0" >&2; exit 1; }

mkdir -p "${ARTIFACTS}"/

require() { command -v "$1" >/dev/null || { echo "Missing: $1"; exit 1; }; }
for b in losetup partprobe mount arch-chroot umount mktemp; do require "$b"; done

MNT="$(mktemp -d)"
cleanup() {
  local path rel_path subdir
  sync
  rm -fr "$MNT/root/initcpio"
  for subdir in hooks install; do
    [[ -d "$INITRD_SCRIPTS/$subdir" ]] || continue
    while IFS= read -r path; do
      rel_path="${path#"$INITRD_SCRIPTS"/}"
      rm -fr "$MNT/etc/initcpio/$rel_path"
    done < <(find "$INITRD_SCRIPTS/$subdir" -mindepth 1)
  done
  umount -l "$MNT/boot/efi"
  umount -l "$MNT"
  losetup -d "$LOOPDEV"
  rmdir "$MNT"
}
trap cleanup EXIT

echo ">> Attaching image"
LOOPDEV="$(losetup --find --show -P "$IMG")"
partprobe "$LOOPDEV"
P1="${LOOPDEV}p1"   # ESP
P3="${LOOPDEV}p3"   # root (btrfs)

mount -o compress-force=zstd:15,noatime "$P3" "$MNT"
mkdir -p "$MNT/boot/efi"
mount "$P1" "$MNT/boot/efi"

# --- drop one-time unit & scripts into the target root ---
echo ">> Installing initramfs one-time unit & scripts"
cp -a "${INITRD_SCRIPTS}"/ "$MNT/root/"
cp -a "${INITRD_SCRIPTS}"/{hooks,install} "$MNT/etc/initcpio/"

# Build our initramfs installer
KERNEL_PKG="$KERNEL_PKG" INITRAMFS_BASENAME="$INITRAMFS_BASENAME" arch-chroot "$MNT" bash -eux <<'CHROOT'
KERNEL_VER=`pacman -Q "$KERNEL_PKG" | sed 's|.* ||; s|\.arch|-arch|'`     # get the version name from the kernel package -- might be incomplete 'though
KERNEL_VER=`ls -1d /lib/modules/${KERNEL_VER}* | sed 's|.*/||'`   # resolve the exact name from the modules dir
mkinitcpio -k $KERNEL_VER -c /root/initcpio/once-mkinitcpio.conf -S autodetect -g "/root/initcpio/${INITRAMFS_BASENAME}" || :
CHROOT

echo "Installer ramdisk was created. Copying to the artifacts directory"
cp -aL "$MNT/boot/${KERNEL_BASENAME}" "${ARTIFACTS}"/ || cp -aL "$MNT/boot/${KERNEL_FALLBACK_BASENAME}" "${ARTIFACTS}/${KERNEL_BASENAME}"
cp -a "$MNT/root/initcpio/${INITRAMFS_BASENAME}" "${ARTIFACTS}/"
chmod 644 "${ARTIFACTS}"/*
ls -l "${ARTIFACTS}"/

echo "Done."
echo
echo "To have it install MutuatechLinux into a running Linux, replace the equivalent /boot files for the ones present in the artifacts/ directory."
echo "Remember you need to preserve the target machine's /boot file names: just rewrite the existing ones with our provided contents."
echo
echo "You can follow the README to test it locally."
echo
echo "When ready, publish with:"
echo "rm -f ${ARTIFACTS}/*.xz && xz -T1 -9kv ${ARTIFACTS}/${KERNEL_BASENAME} ${ARTIFACTS}/${INITRAMFS_BASENAME}"
echo "scp -pr ${ARTIFACTS}/*.xz mutuatec@mutuatech.com:~/public_html/MutuatechLinux/initrd_installers/${TARGET_ARCH}/"
